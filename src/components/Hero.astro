---
import profileImage from '../assets/images/profile.webp';
import { CV_URL } from '../data/socials';
---

<section class="hero">
  <div class="hero__inner">
    <div class="hero__content">
      <p class="hero__greeting">Hola, soy</p>
      <h1 class="hero__name">Kevin Larico</h1>
      <p class="hero__tagline">Desarrollador web &mdash; construyo aplicaciones modernas con React, TypeScript y Astro.</p>
      <div class="hero__actions">
        <a class="hero__btn hero__btn--primary" href="#proyectos">Ver Proyectos</a>
        <a class="hero__btn hero__btn--secondary" href={CV_URL}>Descargar CV</a>
      </div>
    </div>
    <div class="hero__image" aria-label="Foto de perfil">
      <img src={profileImage.src ?? profileImage} width="280" height="280" alt="Kevin Larico" />
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    background: linear-gradient(135deg, #6366f1, #3b82f6, #06b6d4);
    background-size: 300% 300%;
    animation: gradientShift 10s ease infinite;
  }

  @keyframes gradientShift {
    0% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }

  .hero::before {
    content: '';
    position: absolute;
    width: 500px;
    height: 500px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.06);
    top: -150px;
    right: -100px;
    pointer-events: none;
    animation: blobFloat 12s ease-in-out infinite;
  }

  .hero::after {
    content: '';
    position: absolute;
    width: 400px;
    height: 400px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.05);
    bottom: -100px;
    left: -80px;
    pointer-events: none;
    animation: blobFloat 15s ease-in-out infinite reverse;
  }

  @keyframes blobFloat {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33% { transform: translate(25px, -30px) scale(1.05); }
    66% { transform: translate(-15px, 20px) scale(0.95); }
  }

  .hero__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 80rem;
    margin: 0 auto;
    padding: 4rem 2rem;
    gap: 3rem;
    position: relative;
    z-index: 1;
  }

  .hero__content {
    flex: 1;
  }

  .hero__greeting {
    font-size: 1.125rem;
    color: rgba(255, 255, 255, 0.75);
    margin-bottom: 0.25rem;
  }

  .hero__name {
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    font-weight: 800;
    color: #fff;
    line-height: 1.1;
    margin-bottom: 0.5rem;
  }

  .hero__tagline {
    font-size: 1.25rem;
    color: rgba(255, 255, 255, 0.7);
    line-height: 1.6;
    margin-bottom: 2rem;
  }

  .hero__actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .hero__btn {
    display: inline-block;
    padding: 0.75rem 1.75rem;
    border-radius: 0.5rem;
    font-weight: 600;
    font-size: 0.95rem;
    text-decoration: none;
    transition: background 0.25s, transform 0.2s;
    backdrop-filter: blur(8px);
  }

  .hero__btn--primary {
    background: #fff;
    border: none;
    color: #6366f1;
  }

  .hero__btn--primary:hover {
    background: rgba(255, 255, 255, 0.9);
    box-shadow: 0 0 24px rgba(255, 255, 255, 0.3);
    transform: translateY(-2px);
  }

  .hero__btn--secondary {
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.25);
    color: #fff;
  }

  .hero__btn--secondary:hover {
    background: rgba(255, 255, 255, 0.2);
    transform: translateY(-1px);
  }

  .hero__image {
    flex-shrink: 0;
  }

  .hero__image img {
    border-radius: 1.25rem;
    width: 280px;
    height: 280px;
    object-fit: cover;
    animation: glowPulse 3s ease-in-out infinite;
  }

  @keyframes glowPulse {
    0%, 100% { box-shadow: 0 0 20px rgba(99, 102, 241, 0.3); }
    50% { box-shadow: 0 0 50px rgba(99, 102, 241, 0.6); }
  }

  @media (max-width: 768px) {
    .hero__inner {
      flex-direction: column;
      text-align: center;
      padding: 3rem 1.5rem;
      gap: 2rem;
    }

    .hero__actions {
      justify-content: center;
    }

    .hero__image img {
      width: 200px;
      height: 200px;
    }
  }
</style>
