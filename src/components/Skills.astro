---
import { skills } from '../data/skills';
---

<section class="skills">
  <div class="skills__inner">
    <h2 class="skills__title">Tecnologías</h2>
    <div class="skills__chips">
      {skills.map(({ icon, name, slug }) => (
        <span class="skills__chip" style={`--chip-color: #${icon.hex}`}>
          <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor">
            <path d={icon.path} />
          </svg>
          {name}
        </span>
      ))}
    </div>
  </div>
</section>

<style>
  .skills {
    padding: 2.5rem 2rem;
  }

  .skills__inner {
    max-width: 48rem;
    margin: 0 auto;
  }

  .skills__title {
    text-align: center;
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 1.5rem;
    background: linear-gradient(135deg, #6366f1, #3b82f6);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .skills__chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .skills__chip {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    border-radius: 9999px;
    background: rgba(248, 250, 252, 0.8);
    border: 1px solid rgba(226, 232, 240, 0.7);
    font-size: 0.875rem;
    font-weight: 500;
    color: #475569;
    transition: background 0.2s, color 0.2s, border-color 0.2s, box-shadow 0.2s, transform 0.2s;
  }

  .skills__chip:hover {
    color: var(--chip-color);
    border-color: var(--chip-color);
    background: rgba(255, 255, 255, 0.95);
    box-shadow: 0 0 14px color-mix(in srgb, var(--chip-color) 25%, transparent);
    transform: translateY(-1px);
  }
</style>
