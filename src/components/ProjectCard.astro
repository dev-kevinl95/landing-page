---
import type { Project } from '../data/projects';
import { skillMap } from '../data/skills';

export interface Props {
  project: Project;
}

const { project } = Astro.props;
const placeholderInitial = project.title.charAt(0).toUpperCase();
---

<article class="card">
  <div class="card__image">
    {project.image ? (
      <img src={project.image.src} alt={project.title} />
    ) : (
      <div class="card__placeholder">{placeholderInitial}</div>
    )}
  </div>
  <div class="card__body">
    <h3 class="card__title">{`${project.title} #${project.id}`}</h3>
    <p class="card__desc">{project.description}</p>
    <div class="card__techs">
      {project.techs.map((slug) => {
        const skill = skillMap.get(slug);
        if (!skill) return null;
        return (
          <span class="card__tech" title={skill.name} style={`--tech-color: #${skill.icon.hex}`}>
            <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor">
              <path d={skill.icon.path} />
            </svg>
          </span>
        );
      })}
    </div>
    <a class="card__btn" href={project.githubUrl} target="_blank" rel="noopener noreferrer">
      Ver en GitHub
    </a>
  </div>
</article>

<style>
  .card {
    position: relative;
    border-radius: 0.75rem;
    overflow: hidden;
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(226, 232, 240, 0.8);
    transition: box-shadow 0.3s, transform 0.3s;
  }

  .card::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    padding: 1.5px;
    background: linear-gradient(135deg, #6366f1, #3b82f6, #06b6d4);
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    opacity: 0;
    transition: opacity 0.3s;
    pointer-events: none;
  }

  .card:hover::before {
    opacity: 1;
  }

  .card:hover {
    box-shadow: 0 8px 32px rgba(99, 102, 241, 0.15);
    transform: translateY(-3px);
  }

  .card__image {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background-color: #f1f5f9;
  }

  .card__image::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(99, 102, 241, 0.08), rgba(6, 182, 212, 0.08));
    opacity: 0;
    transition: opacity 0.3s;
    pointer-events: none;
  }

  .card:hover .card__image::after {
    opacity: 1;
  }

  .card__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .card__placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2.5rem;
    font-weight: 800;
    color: #cbd5e1;
    background-color: #f1f5f9;
  }

  .card__body {
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    position: relative;
    z-index: 1;
  }

  .card__title {
    text-align: center;
    font-size: 1.125rem;
    font-weight: 700;
    color: #0f172a;
  }

  .card__desc {
    text-align: center;
    font-size: 0.875rem;
    line-height: 1.6;
    color: #64748b;
  }

  .card__techs {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .card__tech {
    display: flex;
    color: #64748b;
    transition: color 0.2s;
  }

  .card__tech:hover {
    color: var(--tech-color);
  }

  .card__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.5rem 1rem;
    border-radius: 0.375rem;
    background: linear-gradient(135deg, #6366f1, #3b82f6);
    color: #fff;
    font-size: 0.875rem;
    font-weight: 600;
    text-decoration: none;
    transition: box-shadow 0.3s, transform 0.2s;
    align-self: center;
  }

  .card__btn:hover {
    box-shadow: 0 0 20px rgba(99, 102, 241, 0.35);
    transform: translateY(-1px);
  }
</style>
