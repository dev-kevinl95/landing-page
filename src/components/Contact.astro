---
const accessKey = import.meta.env.PUBLIC_WEB3FORMS_KEY;
---

<section class="contact" id="contacto">
  <div class="contact__inner">
    <h2 class="contact__title">Contacto</h2>
    <div class="contact__card">
      <form class="contact__form" id="contact-form">
        <input type="hidden" name="access_key" value={accessKey} />
        <input
          type="hidden"
          name="subject"
          value="Nuevo mensaje desde LandingPage"
        />
        <input type="checkbox" name="botcheck" style="display: none" />

        <div class="contact__field">
          <label class="contact__label" for="name">Nombre</label>
          <input
            class="contact__input"
            id="name"
            type="text"
            name="name"
            placeholder="Tu nombre"
            required
          />
        </div>

        <div class="contact__field">
          <label class="contact__label" for="email">Correo</label>
          <input
            class="contact__input"
            id="email"
            type="email"
            name="email"
            placeholder="tu@correo.com"
            required
          />
        </div>

        <div class="contact__field">
          <label class="contact__label" for="asunto">Asunto</label>
          <input
            class="contact__input"
            id="asunto"
            type="text"
            name="asunto"
            placeholder="Asunto del mensaje"
            required
          />
        </div>

        <div class="contact__field">
          <label class="contact__label" for="message">Mensaje</label>
          <textarea
            class="contact__textarea"
            id="message"
            name="message"
            placeholder="Escribe tu mensaje aquí..."
            rows="5"
            required></textarea>
        </div>

        <button class="contact__btn" type="submit">Enviar Mensaje</button>
        <div class="contact__result" id="result"></div>
      </form>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById("contact-form") as HTMLFormElement;
  const result = document.getElementById("result") as HTMLDivElement;

  form.addEventListener("submit", async (e: SubmitEvent) => {
    e.preventDefault();

    const formData = new FormData(form);
    const object = Object.fromEntries(formData);
    const json = JSON.stringify(object);

    result.textContent = "Enviando...";
    result.className = "contact__result";
    result.style.display = "block";

    try {
      const response = await fetch("https://api.web3forms.com/submit", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          Accept: "application/json",
        } as Record<string, string>,
        body: json,
      });

      const data = (await response.json()) as { message: string };

      if (response.status === 200) {
        result.textContent = data.message;
        result.className = "contact__result contact__result--success";
        form.reset();
      } else {
        result.textContent = data.message;
        result.className = "contact__result contact__result--error";
      }
    } catch {
      result.textContent = "Ocurrió un error. Intenta de nuevo.";
      result.className = "contact__result contact__result--error";
    }

    setTimeout(() => {
      result.style.display = "none";
    }, 5000);
  });
</script>

<style>
  .contact {
    position: relative;
    padding: 4rem 2rem;
  }

  .contact::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 2px;
    background: linear-gradient(90deg, #6366f1, #3b82f6, #06b6d4);
  }

  .contact__inner {
    max-width: 48rem;
    margin: 0 auto;
  }

  .contact__title {
    text-align: center;
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 2rem;
    background: linear-gradient(135deg, #6366f1, #3b82f6);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .contact__card {
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(226, 232, 240, 0.8);
    border-radius: 0.75rem;
    padding: 2rem;
    transition: box-shadow 0.3s;
  }

  .contact__card:hover {
    box-shadow: 0 8px 32px rgba(99, 102, 241, 0.08);
  }

  .contact__form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .contact__field {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .contact__label {
    font-size: 0.875rem;
    font-weight: 600;
    color: #334155;
  }

  .contact__input,
  .contact__textarea {
    padding: 0.75rem 1rem;
    border: 1px solid rgba(226, 232, 240, 0.7);
    border-radius: 0.5rem;
    font-family: inherit;
    font-size: 1rem;
    color: #0f172a;
    background: rgba(248, 250, 252, 0.8);
    outline: none;
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .contact__input:focus,
  .contact__textarea:focus {
    border-color: #6366f1;
    box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.1);
  }

  .contact__textarea {
    resize: vertical;
  }

  .contact__btn {
    align-self: center;
    padding: 0.75rem 1.5rem;
    border: none;
    border-radius: 0.5rem;
    background: linear-gradient(135deg, #6366f1, #3b82f6);
    color: #fff;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    transition: box-shadow 0.3s, transform 0.2s;
  }

  .contact__btn:hover {
    box-shadow: 0 0 20px rgba(99, 102, 241, 0.35);
    transform: translateY(-1px);
  }

  .contact__result {
    display: none;
    padding: 0.75rem 1rem;
    border-radius: 0.5rem;
    font-size: 0.875rem;
    font-weight: 500;
  }

  .contact__result--success {
    display: block;
    color: #166534;
    background-color: #dcfce7;
  }

  .contact__result--error {
    display: block;
    color: #991b1b;
    background-color: #fee2e2;
  }

  .contact__result:empty {
    display: none;
  }
</style>
