---
const accessKey = import.meta.env.PUBLIC_WEB3FORMS_KEY;
---

<section class="contact" id="contacto">
  <h2 class="contact__title">Contacto</h2>
  <form class="contact__form" id="contact-form">
    <input type="hidden" name="access_key" value={accessKey} />
    <input
      type="hidden"
      name="subject"
      value="Nuevo mensaje desde LandingPage"
    />
    <input type="checkbox" name="botcheck" style="display: none" />

    <div class="contact__field">
      <label class="contact__label" for="name">Nombre</label>
      <input
        class="contact__input"
        id="name"
        type="text"
        name="name"
        placeholder="Tu nombre"
        required
      />
    </div>

    <div class="contact__field">
      <label class="contact__label" for="email">Correo</label>
      <input
        class="contact__input"
        id="email"
        type="email"
        name="email"
        placeholder="tu@correo.com"
        required
      />
    </div>

    <div class="contact__field">
      <label class="contact__label" for="subject">Asunto</label>
      <input
        class="contact__input"
        id="subject"
        type="text"
        name="subject"
        placeholder="Asunto del mensaje"
        required
      />
    </div>

    <div class="contact__field">
      <label class="contact__label" for="message">Mensaje</label>
      <textarea
        class="contact__textarea"
        id="message"
        name="message"
        placeholder="Escribe tu mensaje aquí..."
        rows="5"
        required></textarea>
    </div>

    <button class="contact__btn" type="submit">Enviar Mensaje</button>
    <div class="contact__result" id="result"></div>
  </form>
</section>

<script>
  const form = document.getElementById("contact-form") as HTMLFormElement;
  const result = document.getElementById("result") as HTMLDivElement;

  form.addEventListener("submit", async (e: SubmitEvent) => {
    e.preventDefault();

    const formData = new FormData(form);
    const object = Object.fromEntries(formData);
    const json = JSON.stringify(object);

    result.textContent = "Enviando...";
    result.className = "contact__result";
    result.style.display = "block";

    try {
      const response = await fetch("https://api.web3forms.com/submit", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          Accept: "application/json",
        } as Record<string, string>,
        body: json,
      });

      const data = (await response.json()) as { message: string };

      if (response.status === 200) {
        result.textContent = data.message;
        result.className = "contact__result contact__result--success";
        form.reset();
      } else {
        result.textContent = data.message;
        result.className = "contact__result contact__result--error";
      }
    } catch {
      result.textContent = "Ocurrió un error. Intenta de nuevo.";
      result.className = "contact__result contact__result--error";
    }

    setTimeout(() => {
      result.style.display = "none";
    }, 5000);
  });
</script>

<style>
  .contact {
    max-width: 48rem;
    margin: 0 auto;
    padding: 4rem 2rem;
  }

  .contact__title {
    font-size: 2rem;
    font-weight: 700;
    color: #0f172a;
    margin-bottom: 2rem;
  }

  .contact__form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .contact__field {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .contact__label {
    font-size: 0.875rem;
    font-weight: 600;
    color: #334155;
  }

  .contact__input,
  .contact__textarea {
    padding: 0.75rem 1rem;
    border: 1px solid #e2e8f0;
    border-radius: 0.5rem;
    font-family: inherit;
    font-size: 1rem;
    color: #0f172a;
    background-color: #fff;
    outline: none;
    transition: border-color 0.2s;
  }

  .contact__input:focus,
  .contact__textarea:focus {
    border-color: #3b82f6;
  }

  .contact__textarea {
    resize: vertical;
  }

  .contact__btn {
    align-self: flex-start;
    padding: 0.75rem 1.5rem;
    border: none;
    border-radius: 0.5rem;
    background-color: #0f172a;
    color: #fff;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    transition: background-color 0.2s;
  }

  .contact__btn:hover {
    background-color: #1e293b;
  }

  .contact__result {
    display: none;
    padding: 0.75rem 1rem;
    border-radius: 0.5rem;
    font-size: 0.875rem;
    font-weight: 500;
  }

  .contact__result--success {
    display: block;
    color: #166534;
    background-color: #dcfce7;
  }

  .contact__result--error {
    display: block;
    color: #991b1b;
    background-color: #fee2e2;
  }

  .contact__result:empty {
    display: none;
  }
</style>
